generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id          String   @id @default(uuid())
  name        String
  description String?
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  guestTokens GuestToken[]
  media       Media[]

  @@map("events")
}

model GuestToken {
  id        String    @id @default(uuid())
  eventId   String
  token     String    @unique
  name      String?
  active    Boolean   @default(true)

  // Permissions
  canView   Boolean   @default(true)
  canUpload Boolean   @default(false)
  canDelete Boolean   @default(false)

  // Constraints
  mediaIds  String[]  @default([])
  expiresAt DateTime?

  createdAt DateTime  @default(now())

  event Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  media Media[]

  @@index([eventId])
  @@index([active])
  @@map("guest_tokens")
}

model Media {
  id                String           @id @default(uuid())
  eventId           String
  guestTokenId      String?
  filename          String
  originalName      String
  mimeType          String
  size              BigInt
  storageKey        String
  type              MediaType
  uploadedBy        UploaderType
  thumbnail         String?
  thumbnailFallback String?
  preview           String?
  previewFallback   String?
  processingStatus  ProcessingStatus @default(completed)
  processingError   String?
  createdAt         DateTime         @default(now())

  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guestToken GuestToken? @relation(fields: [guestTokenId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([guestTokenId])
  @@index([createdAt])
  @@index([processingStatus])
  @@map("media")
}

enum MediaType {
  photo
  video
}

enum UploaderType {
  photographer
  guest
}

enum ProcessingStatus {
  pending
  processing
  completed
  failed
}
