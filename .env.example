# Node environment
NODE_ENV=development

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/media_gallery"

# ===================
# Upload Configuration
# ===================

# Chunk size for chunked uploads (bytes)
# Default: 5MB (5242880)
# NUXT_PUBLIC_UPLOAD_CHUNK_SIZE=5242880

# File size threshold for using chunked uploads (bytes)
# Files larger than this will use tus protocol
# Default: 50MB (52428800)
# NUXT_PUBLIC_UPLOAD_CHUNKED_THRESHOLD=52428800

# Maximum file size for standard (non-chunked) uploads (bytes)
# Default: 500MB (524288000)
# NUXT_PUBLIC_UPLOAD_MAX_STANDARD_SIZE=524288000

# Maximum file size for chunked uploads (bytes)
# Default: 10GB (10737418240)
# NUXT_PUBLIC_UPLOAD_MAX_CHUNKED_SIZE=10737418240

# Server-side max chunked upload size (should match public config)
# Default: 10GB (10737418240)
# NUXT_UPLOAD_MAX_CHUNKED_SIZE=10737418240

# Hours before incomplete uploads are cleaned up
# Default: 24
# NUXT_UPLOAD_STALE_THRESHOLD_HOURS=24

# ===================
# CORS Configuration
# ===================

# Application URL for CORS origin validation
# In production, set this to your domain (e.g., https://yourdomain.com)
# If not set, CORS will use request origin (safe for development)
# NUXT_PUBLIC_APP_URL=https://yourdomain.com

# Alternative: Server-side CORS origin override
# Takes precedence over NUXT_PUBLIC_APP_URL if set
# NUXT_CORS_ORIGIN=https://yourdomain.com
